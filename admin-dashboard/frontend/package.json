{
  "name": "admin-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "npx tsx --tsconfig tsconfig.app.json --test src/features/alarms/selectors.test.ts src/features/members/selectors.test.ts src/features/members/members-page.performance.test.ts src/features/stats/selectors.test.ts src/features/stats/lib/systemStats.test.ts src/features/streams/lib/media.test.mjs src/api/blueprint-section-8.test.ts src/api/msw.integration.test.ts src/routes/route-definitions.test.ts src/hooks/useHeartbeat.test.ts src/lib/queryState.test.ts src/lib/theme.test.ts src/index-html.test.ts",
    "preview": "vite preview",
    "generate:api": "mkdir -p ../backend/docs && (cd ../backend && go run ./cmd/export-openapi > docs/swagger.json) && swagger-typescript-api generate -p ../backend/docs/swagger.json -o src/api/generated --axios --modular"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "dompurify": "^3.4.11",
    "esbuild": "^0.28.1",
    "flatted": "^3.4.2",
    "defu": "^6.1.7",
    "yaml": "^2.8.3",
    "follow-redirects": "^1.16.0",
    "oas-resolver": {
      "yaml": "1.10.3"
    },
    "oas-linter": {
      "yaml": "1.10.3"
    },
    "oas-validator": {
      "yaml": "1.10.3"
    },
    "swagger2openapi": {
      "yaml": "1.10.3"
    }
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.6",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "msw": "^2.15.0",
    "swagger-typescript-api": "^13.12.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
