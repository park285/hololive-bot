{
  "name": "admin-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "npx tsx --tsconfig tsconfig.app.json --test src/features/alarms/selectors.test.ts src/features/members/selectors.test.ts src/features/members/members-page.performance.test.ts src/features/stats/selectors.test.ts src/features/stats/lib/systemStats.test.ts src/features/streams/lib/media.test.mjs src/api/blueprint-section-8.test.ts src/api/msw.integration.test.ts src/routes/route-definitions.test.ts src/hooks/useHeartbeat.test.ts src/lib/polling.test.ts src/lib/queryState.test.ts src/lib/theme.test.ts",
    "preview": "vite preview",
    "generate:api": "mkdir -p ../backend/docs && (cd ../backend && go run ./cmd/export-openapi > docs/swagger.json) && swagger-typescript-api generate -p ../backend/docs/swagger.json -o src/api/generated --axios --modular"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "dompurify": "^3.4.11",
    "esbuild": "^0.28.1",
    "flatted": "^3.4.2",
    "defu": "^6.1.7",
    "yaml": "^2.8.3",
    "follow-redirects": "^1.16.0",
    "oas-resolver": {
      "yaml": "1.10.3"
    },
    "oas-linter": {
      "yaml": "1.10.3"
    },
    "oas-validator": {
      "yaml": "1.10.3"
    },
    "swagger2openapi": {
      "yaml": "1.10.3"
    }
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "msw": "^2.13.3",
    "swagger-typescript-api": "^13.6.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
