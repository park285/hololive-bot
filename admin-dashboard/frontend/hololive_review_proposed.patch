+func (s *Scheduler) nextDispatchDelay(workerChannelFull bool) time.Duration {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+
+	if workerChannelFull {
+		return 50 * time.Millisecond
+	}
+	if len(s.jobs) == 0 {
+		return time.Second
+	}
+
+	wait := time.Until(s.jobs[0].NextRunAt)
+	if wait < 0 {
+		return 0
+	}
+	return wait
+}
