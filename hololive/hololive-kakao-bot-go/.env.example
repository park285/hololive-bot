# Iris Server Configuration
IRIS_BASE_URL=http://localhost:3000

# Bot Webhook Server Configuration
SERVER_PORT=30001

# Admin Console Authentication is handled by admin-dashboard (SSOT)
# (hololive-bot-go는 /api/holo/* 도메인 API만 제공)

# KakaoTalk Configuration
# 알림을 받을 카카오톡 방 이름들 (쉼표로 구분)
KAKAO_ROOMS=홀로라이브 알림방

# Holodex API Keys (최대 5개까지 로테이션)
HOLODEX_API_KEY_1=your_holodex_api_key_here
HOLODEX_API_KEY_2=
HOLODEX_API_KEY_3=
HOLODEX_API_KEY_4=
HOLODEX_API_KEY_5=

# Valkey - Cache
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_PASSWORD=
CACHE_DB=0

# Valkey - MQ (카카오 메시지 라우팅용, Docker 포트 1833 사용)
MQ_HOST=localhost
MQ_PORT=1833
MQ_PASSWORD=
MQ_STREAM_KEY=kakao:hololive
MQ_CONSUMER_GROUP=hololive-bot-group
MQ_CONSUMER_NAME=consumer-1

# Notification Settings
NOTIFICATION_ADVANCE_MINUTES=5
CHECK_INTERVAL_SECONDS=60

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/bot.log

# Bot Command Prefix
BOT_PREFIX=!
BOT_SELF_USER=iris

# Chzzk (치지직) Open API 설정
# - 개발자 센터: https://developers.chzzk.naver.com
# - Client 인증 방식 사용 (OAuth 불필요)
CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=

# YouTube 스크래퍼 프록시 (SOCKS5)
# - 스크래퍼(HTML) 트래픽만 프록시를 사용합니다.
# - 예: OpenVPN 컨테이너가 제공하는 로컬 SOCKS5(127.0.0.1:1080)
SCRAPER_PROXY_ENABLED=false
SCRAPER_PROXY_URL=socks5://127.0.0.1:1080

# NordVPN OpenVPN (docker-compose.vpn-scraper.yml 용)
# - NordVPN 계정 로그인 비밀번호가 아니라 "Service credentials"를 사용해야 합니다.
NORDVPN_USERNAME=
NORDVPN_PASSWORD=
NORDVPN_OVPN_PATH=./jp804.nordvpn.com.udp.ovpn
VPN_KILLSWITCH=1
