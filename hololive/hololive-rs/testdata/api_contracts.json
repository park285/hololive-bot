    "admin_auth": {
      "base_path": "/api/auth",
      "auth": "Session/JWT (Authorization: Bearer <token>)",
      "notes": [
        "writeAuthError 응답 형식: {success:false,error:<code>}"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/auth/register",
          "description": "사용자 등록",
          "status_codes": [201, 400, 409, 500],
          "request": { "query_params": [], "body": "{email:string,password:string,displayName:string}" },
          "response": { "content_type": "application/json", "body_schema": "{success:true,user:{id,email,displayName,createdAt}}" },
          "error_schema": { "success": false, "error": "string" },
          "timeout": "10s"
        },
        {
          "method": "POST",
          "path": "/api/auth/login",
          "description": "로그인 및 세션 토큰 발급",
          "status_codes": [200, 400, 401, 403, 429, 500],
          "request": { "query_params": [], "body": "{email:string,password:string}" },
          "response": { "content_type": "application/json", "body_schema": "{success:true,session:{token,expiresAt},user:{id,email,displayName,avatarUrl}}" },
          "error_schema": { "success": false, "error": "string" },
          "timeout": "10s"
        },
        {
          "method": "POST",
          "path": "/api/auth/logout",
          "description": "세션 무효화",
          "status_codes": [200, 401, 500],
          "request": { "headers": ["Authorization: Bearer <token>"], "query_params": [], "body": null },
          "response": { "content_type": "application/json", "body_schema": "{success:true}" },
          "error_schema": { "success": false, "error": "string" },
          "timeout": "10s"
        },
        {
          "method": "POST",
          "path": "/api/auth/refresh",
          "description": "세션 토큰 갱신",
          "status_codes": [200, 401, 500],
          "request": { "headers": ["Authorization: Bearer <token>"], "query_params": [], "body": null },
          "response": { "content_type": "application/json", "body_schema": "{success:true,session:{token,expiresAt}}" },
          "error_schema": { "success": false, "error": "string" },
          "timeout": "10s"
        },
        {
          "method": "GET",
          "path": "/api/auth/me",
          "description": "현재 사용자 정보",
          "status_codes": [200, 401, 500],
          "request": { "headers": ["Authorization: Bearer <token>"], "query_params": [], "body": null },
          "response": { "content_type": "application/json", "body_schema": "{success:true,user:{id,email,displayName,avatarUrl,createdAt}}" },
          "error_schema": { "success": false, "error": "string" },
          "timeout": "10s"
        },
        {
          "method": "POST",
          "path": "/api/auth/password/reset-request",
          "description": "비밀번호 재설정 요청",
          "status_codes": [200, 400, 429, 500],
          "request": { "query_params": [], "body": "{email:string}" },
          "response": { "content_type": "application/json", "body_schema": "{success:true,message:string}" },
          "error_schema": { "success": false, "error": "string" },
          "timeout": "10s"
        },
        {
