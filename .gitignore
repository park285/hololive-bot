# ============================================
# Hololive Bot Root .gitignore
# ============================================

# ============================================
# Kubernetes (기존 항목)
# ============================================
k8s/base/monitoring/charts/
k8s/base/secret-*.yaml

# ============================================
# Secrets & Credentials (CRITICAL)
# ============================================
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
KR.pub
ssh-key-2026-03-09.key.pub
credentials.json
secrets.yml
secrets.yaml
secrets/*
!secrets/.gitkeep

# ============================================
# Go Build Outputs
# ============================================
# hololive-kakao-bot-go 빌드 산출물
hololive/hololive-kakao-bot-go/bot
hololive/hololive-kakao-bot-go/fetch_profiles
hololive/hololive-kakao-bot-go/config.json
hololive/hololive-stream-ingester/youtube-scraper

# ============================================
# Rust
# ============================================
target/
*.rs.bk

# ============================================
# IDE
# ============================================
# IntelliJ IDEA
.idea/
*.iml

# VSCode
.vscode/
*.code-workspace

# ============================================
# Logs
# ============================================
*.log
logs/*
logs/**/*
!logs/.gitkeep
!**/internal/logs/
!scripts/logs/
gc.log*

# ============================================
# OS Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory
.Trash-*

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.swp
*.swo
*~
tmp/
backup/
backups/
artifacts/*
!artifacts/architecture/
artifacts/architecture/*
!artifacts/architecture/go-workspace-import-graph.txt

# Compressed archives
*.tar.gz
BUNDLE_MANIFEST.txt

# ============================================
# AI Tooling Artifacts (Local Only)
# ============================================
.ai-lessons/
/ai-guard.config.json
.playwright-cli/
.serena/
.claude/
.gemini/
.codex/
.codex-input/
.mcp.json
.opencode/
*.ai.md
*-ai-notes.md
*.backup
*.backup-*
AGENTS.md
.plan/
.PLAN/
CLAUDE.md
CLAUDE_MD_ARCHITECTURE.md
.omx/
.omc/
.omx-memory/
/dist/
/scripts/ai-guard-hook.mjs

# Temporary analysis files (LLM workflow)
*_files.txt
*_tests.txt
*_no_tests.txt
/hololive*_review*.md
/gen_image.py
/README.txt

# ============================================
# Personal/Draft Files
# ============================================
NOTES.md
TODO.md
SCRATCH.md
*.draft.md
.notes/
notes/

# ============================================
# Test & Coverage
# ============================================
.test/
coverage/
*.gcov
coverage.out
cover.out
coverage.html
admin-dashboard/frontend/test-results/
admin-dashboard/frontend/full-page.png

# ============================================
# Database
# ============================================
*.db
*.mv.db
*.trace.db
dump.rdb

# ============================================
# Node.js
# ============================================
node_modules/

# ============================================
# Runtime & Process Files
# ============================================
*.pid
nohup.out

# ============================================
# Hololive Scraper RS Reports
# ============================================
hololive/hololive-rs/docs/reports/**/*.json
hololive/hololive-rs/docs/reports/**/*.tsv

# ============================================
# Local Data & Config
# ============================================
/config/
/data/
/runtime-config/*
!/runtime-config/.gitkeep
!/runtime-config/README.md
!/runtime-config/*.example

# ============================================
# VPN Config
# ============================================
*.ovpn

# ============================================
# IDE Agent Configs
# ============================================
.agents/
.junie/

# ============================================
# Agent Workflows (Local Only)
# ============================================
.agent/
.tasklists/

# ============================================
# Deploy Snapshots
# ============================================
.deploy-snapshots/

# ============================================
# Explicitly Include (Override)
# ============================================
!.env.example
!README.md
!LICENSE
!CHANGELOG.md
!docs/
docs/.omx/
docs/doc-gen/
docs/superpowers/

# Build outputs
admin-dashboard/backend/admin

.worktrees/
