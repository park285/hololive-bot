table inet admin_dashboard_ingress {
	chain input {
		type filter hook input priority -20; policy accept;

		ip daddr 100.100.1.3 tcp dport 30191 iifname "lo" accept
		ip daddr 100.100.1.3 tcp dport 30191 iifname "tailscale0" ip saddr 100.100.1.5 accept
		ip daddr 100.100.1.3 tcp dport 30191 reject with tcp reset
	}
}
