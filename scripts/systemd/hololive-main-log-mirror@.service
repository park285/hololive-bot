[Unit]
Description=Hololive remote logs into repo logs (%i)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=kapu
Group=kapu
WorkingDirectory=/home/kapu/work/iris-stack/hololive-bot
EnvironmentFile=-/etc/hololive/log-mirror.env
Environment=LOG_ROOT=/home/kapu/work/iris-stack/hololive-bot/logs
Environment=HOL_LOG_OSAKA_SSH_KEY=/home/kapu/work/iris-stack/hololive-bot/KR.key
Environment=HOL_LOG_SEOUL_SSH_KEY=/home/kapu/work/iris-stack/hololive-bot/KR.key
ExecStart=/home/kapu/work/iris-stack/hololive-bot/scripts/logs/remote-sync-main-logs.sh once %i
UMask=0027
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6
