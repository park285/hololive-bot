# ============================================
# Hololive Bot Environment Variables (.env.example)
# ============================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# 모든 시크릿은 placeholder로 제공되며 운영 전 반드시 변경해야 합니다.

# ============================================
# PostgreSQL (필수)
# ============================================
DB_PASSWORD=change_me_to_secure_password
POSTGRES_ADMIN_USER=postgres_admin
HOLOLIVE_DB_USER=hololive_runtime
HOLOLIVE_MIGRATOR_USER=hololive_migrator
HOLOLIVE_SCRAPER_USER=hololive_scraper
HOLOLIVE_SCRAPER_PASSWORD=change_me

# ============================================
# Valkey (Redis protocol) - Cache
# ============================================
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_PASSWORD=
# CACHE_SOCKET_PATH=/var/run/valkey/valkey-cache.sock

# ============================================
# Hololive API Authentication
# ============================================
API_SECRET_KEY=change_me_base64_secret

# ============================================
# Iris (Kakao Bot)
# ============================================
IRIS_BASE_URL=
IRIS_WEBHOOK_TOKEN=change_me_iris_webhook_token
IRIS_BOT_TOKEN=change_me_iris_bot_token
# 운영상 동일 값을 사용할 수는 있지만 변수는 분리해서 유지하세요.
# compose 배포는 기본값 없이 이 세 값을 명시 주입해야 합니다.

# ============================================
# Holodex API Keys (로테이션 풀)
# ============================================
HOLODEX_API_KEY_1=your_holodex_key_1
HOLODEX_API_KEY_2=your_holodex_key_2
HOLODEX_API_KEY_3=your_holodex_key_3
HOLODEX_API_KEY_4=your_holodex_key_4
HOLODEX_API_KEY_5=your_holodex_key_5

# ============================================
# YouTube Data API
# ============================================
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_ENABLE_QUOTA_BUILDING=true

# ============================================
# 외부 API Keys
# ============================================
KASI_API_KEY=your_kasi_api_key
KMA_API_KEY=your_kma_api_key
AIRKOREA_API_KEY=your_airkorea_api_key
KAKAO_REST_API_KEY=your_kakao_rest_api_key
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ============================================
# Google OAuth (Calendar/Tasks)
# ============================================
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
OAUTH_BASE_URL=https://your-domain.com
GOOGLE_REDIRECT_URI=https://your-domain.com/oauth/google/callback
TOKEN_ENCRYPTION_KEY=change_me_base64_32_byte_key

# ============================================
# CLIProxy LLM (행사 요약 + 멤버뉴스)
# ============================================
CLIPROXY_ENABLED=true
CLIPROXY_BASE_URL=http://host.docker.internal:8787/v1
CLIPROXY_API_KEY=your_cliproxy_api_key
CLIPROXY_MODEL=gpt-5.4
CLIPROXY_REASONING_EFFORT=high

# ============================================
# YouTube Scraper Proxy (Optional)
# ============================================
YOUTUBE_INGESTION_ENABLED=true
PHOTO_SYNC_ENABLED=true
YOUTUBE_COMMUNITY_SHORTS_BIGBANG_ENABLED=false
YOUTUBE_COMMUNITY_SHORTS_BIGBANG_CUTOVER_AT=
SCRAPER_PROXY_ENABLED=false
SCRAPER_PROXY_URL=
SCRAPER_WORKER_COUNT=2
SCRAPER_VIDEOS_SECONDS=300
SCRAPER_SHORTS_SECONDS=120
SCRAPER_COMMUNITY_SECONDS=120
SCRAPER_STATS_SECONDS=21600
SCRAPER_LIVE_SECONDS=300

# ============================================
# Alarm / Twitch
# ============================================
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ============================================
# Major Event Scraper
# ============================================
MAJOREVENT_SCRAPER_ENABLED=false

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
# compose 운영 기본값:
# - application stdout/stderr = SSOT (`docker compose logs`)
# - file mirror = /home/kapu/gemini/hololive-bot/logs/*.log
# - compressed backups = /home/kapu/gemini/hololive-bot/logs/archive/*.gz
# 아래 값은 file mirror 로테이션 정책 기본값입니다.
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS=true
# runtime environment (`APP_ENV`) only; legacy `OTEL_ENVIRONMENT` is removed.
APP_ENV=production
# 보조 로그 파일은 기본 비활성입니다.
# ENABLE_LOG_MIRROR=1       # logs/mirror 사용 시에만
# ENABLE_LOG_AUX_FILES=1    # logs/backfill, logs/canary, logs/cron 사용 시에만
# pure stdout-only가 필요할 때만 LOG_DIR를 직접 override 하세요.
# LOG_DIR=logs
