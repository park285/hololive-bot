{
  "name": "hololive-main-server-logs-mirror",
  "version": "2.0",
  "purpose": "Mirror Osaka split-host logs into main server /logs path",
  "main_log_root": "/logs",
  "mirrored_top_level_files": [
    "/logs/youtube-scraper.log",
    "/logs/stream-ingester.log"
  ],
  "actual_remote_mirror_root": "/logs/remote/osaka",
  "entrypoint": "scripts/logs/remote-sync-main-logs.sh",
  "systemd_units": [
    "scripts/systemd/hololive-main-log-mirror@.service",
    "scripts/systemd/hololive-main-log-mirror@.timer"
  ],
  "verifier": "docs/history/plan-kits/hololive-main-server-logs-mirror-v2/scripts/verify-main-log-mirror-v2.sh",
  "osaka_log_rotation": {
    "app_file_log_max_size_mb": 20,
    "app_file_log_max_backups": 10,
    "app_file_log_max_age_days": 14,
    "docker_json_file_max_size": "5m",
    "docker_json_file_max_file": 3
  },
  "admin_scope": "excluded"
}
