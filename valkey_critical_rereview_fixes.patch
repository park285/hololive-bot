+func (r *youTubePollTargetRefresher) loadAlarmChannelIDsFromCache(ctx context.Context) ([]string, error) {
+	version, versionKnown, err := r.readAlarmChannelRegistryVersion(ctx)
+	if err != nil {
+		return nil, err
+	}
+
+	if versionKnown &&
+		r.hasLastAlarmRegistryVersion &&
+		r.lastAlarmRegistryVersion == version &&
+		r.lastAlarmChannelIDs != nil {
+		return append([]string(nil), r.lastAlarmChannelIDs...), nil
+	}
+
+	channelIDs, err := r.cacheService.SMembers(ctx, sharedalarmkeys.AlarmChannelRegistryKey)
+	if err != nil {
+		return nil, err
+	}
+
+	if versionKnown {
+		r.lastAlarmRegistryVersion = version
+		r.hasLastAlarmRegistryVersion = true
+	} else {
+		// Missing/zero version means this runtime cannot prove that the local
+		// snapshot is fresh. Keep the snapshot for local state, but never use it
+		// to skip SMEMBERS until a positive version is observed.
+		r.hasLastAlarmRegistryVersion = false
+		r.lastAlarmRegistryVersion = 0
+	}
+	r.lastAlarmChannelIDs = append([]string(nil), channelIDs...)
+
+	return channelIDs, nil
+}
+
+func (r *youTubePollTargetRefresher) readAlarmChannelRegistryVersion(ctx context.Context) (int64, bool, error) {
+	exists, err := r.cacheService.Exists(ctx, sharedalarmkeys.AlarmChannelRegistryVersionKey)
+	if err != nil {
+		return 0, false, err
+	}
+	if !exists {
+		return 0, false, nil
+	}
+
+	var version int64
+	if err := r.cacheService.Get(ctx, sharedalarmkeys.AlarmChannelRegistryVersionKey, &version); err != nil {
+		return 0, false, err
+	}
+	return version, version > 0, nil
+}
