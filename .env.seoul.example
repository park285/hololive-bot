COMPOSE_ENV_FILE=./.env.seoul
SEOUL_POSTGRES_HOST=100.100.1.3
SEOUL_POSTGRES_PORT=5433
SEOUL_CACHE_HOST=100.100.1.3
SEOUL_CACHE_PORT=6379
# 중앙 .env의 CACHE_PASSWORD와 동일한 URL-safe hex 값을 사용합니다.
CACHE_PASSWORD=change_me_same_as_central_cache_password
SEOUL_CLIPROXY_BASE_URL=http://100.100.1.3:8787/v1
CACHE_SOCKET_PATH=
POSTGRES_SOCKET_PATH=
